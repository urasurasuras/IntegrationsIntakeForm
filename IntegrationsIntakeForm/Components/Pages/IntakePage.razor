@page "/intake"
@using IntegrationsIntakeForm
@using IntegrationsIntakeForm.Models
@rendermode InteractiveServer

<div class="container-fluid p-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2 class="m-0">Integration Intake Form</h2>
        </div>
        <div class="card-body">
            
            @* --- Section 1: Integration Features --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">1. Integration Features</h3>
                <p class="text-muted">Select the capabilities this integration will support.</p>
                <div class="d-flex flex-wrap">
                    @foreach (var feature in _formModel.Features)
                    {
                        <div class="form-check form-check-inline mr-4">
                            <input class="form-check-input" type="checkbox" @bind="feature.IsEnabled"
                                   id="@feature.Name.Replace(" ", "-")">
                                <label class="form-check-label font-weight-bold"
                                       for="@feature.Name.Replace(" ", "-")">@feature.Name</label>
                            </div>
                        }
                    </div>
                </section>

                @* --- Section 2: Required ID Fields --- *@
                <section class="form-section mb-5">
                    <h3 class="mb-3">2. Required ID Fields Mapping</h3>
                    <p class="text-muted">Define the specific mapping rules for each required ID field.</p>
                    @foreach (RequiredField field in _formModel.RequiredIdFields)
                    {
                        <MappingRuleEditor Field="@field" @bind-Mapping="field.Mapping" />
                    }
                </section>

                @* --- Section 3: Time Windows --- *@
                <section class="form-section mb-5">
                    <h3 class="mb-3">3. Pickup / Delivery Target Time Windows Mapping</h3>
                
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Field</th>
                                    <th class="text-center">Date Source</th>
                                    <th class="text-center">Time Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="font-weight-bold">Pickup From</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.PickupFromDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.PickupFromTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Pickup To</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm" @bind="_formModel.PickupToDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm" @bind="_formModel.PickupToTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Delivery From</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryFromDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryFromTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Delivery To</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryToDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryToTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                
            </div>
            <div class="card-footer d-flex justify-content-end">
                <button class="btn btn-outline-secondary mr-2" @onclick="ResetForm">Reset Form</button>
                <button class="btn btn-primary" @onclick="SubmitForm">Submit Integration Request</button>
            </div>
        </div>
    </div>

@code {
    private IntegrationIntakeModel _formModel = new IntegrationIntakeModel();
    private string _submissionMarkdown = string.Empty;
    private bool _showSubmissionResult = false;
    
    private string GetLabelForType(NoItemizationType type)
    {
        return type switch
        {
            NoItemizationType.FromFileWithMapping => "From File (with mapping)",
            NoItemizationType.SingularDefaultFromConfig => "Singular Default (from config)",
            _ => type.ToString()
        };
    }

    private void ResetForm()
    {
        _formModel = new IntegrationIntakeModel();
        _showSubmissionResult = false;
    }

    private void SubmitForm()
    {
        var markdown = GenerateMarkdown();
        _submissionMarkdown = markdown;
        _showSubmissionResult = true;
        Console.WriteLine("Form submitted. Markdown generated:");
        Console.WriteLine(markdown);
    }

    private string GenerateMarkdown()
    {
        var sb = new System.Text.StringBuilder();
        
        sb.AppendLine("# Integration Intake Form Submission");
        sb.AppendLine($"Generated: {DateTime.Now:g}");
        sb.AppendLine();
        
        // Section 1: Integration Features
        sb.AppendLine("## 1. Integration Features");
        var enabledFeatures = _formModel.Features.Where(f => f.IsEnabled).ToList();
        if (enabledFeatures.Any())
        {
            foreach (var feature in enabledFeatures)
            {
                sb.AppendLine($"- ✓ {feature.Name}");
            }
        }
        else
        {
            sb.AppendLine("- No features selected");
        }
        sb.AppendLine();
        
        // Section 2: Required ID Fields Mapping
        sb.AppendLine("## 2. Required ID Fields Mapping");
        foreach (var field in _formModel.RequiredIdFields)
        {
            sb.AppendLine($"### {field.FieldName}");
            sb.AppendLine($"- **Mapping:** {field.Mapping}");
        }
        sb.AppendLine();
        
        // Section 3: Time Windows Mapping
        sb.AppendLine("## 3. Pickup / Delivery Target Time Windows Mapping");
        sb.AppendLine();
        sb.AppendLine("| Field | Date Source | Time Source |");
        sb.AppendLine("|-------|-------------|-------------|");
        sb.AppendLine($"| Pickup From | {_formModel.PickupFromDateSource} | {_formModel.PickupFromTimeSource} |");
        sb.AppendLine($"| Pickup To | {_formModel.PickupToDateSource} | {_formModel.PickupToTimeSource} |");
        sb.AppendLine($"| Delivery From | {_formModel.DeliveryFromDateSource} | {_formModel.DeliveryFromTimeSource} |");
        sb.AppendLine($"| Delivery To | {_formModel.DeliveryToDateSource} | {_formModel.DeliveryToTimeSource} |");
        
        return sb.ToString();
    }


    private async Task CopyToClipboard()
    {
        // This would require JS interop to copy to clipboard
        Console.WriteLine("Markdown copied to clipboard!");
    }
}

@if (_showSubmissionResult)
{
    <section class="form-section mb-5 mt-5 p-4 bg-light border border-success rounded">
        <h3 class="mb-3">✓ Submission Summary</h3>
        <div class="bg-white p-3 border rounded" style="max-height: 400px; overflow-y: auto;">
            <pre>@_submissionMarkdown</pre>
        </div>
        <button class="btn btn-sm btn-info mt-3" @onclick="CopyToClipboard">
            📋 Copy to Clipboard
        </button>
    </section>
}
