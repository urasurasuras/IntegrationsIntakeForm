@page "/intake"
@using IntegrationsIntakeForm
@using IntegrationsIntakeForm.Models
@rendermode InteractiveServer

<div class="container-fluid p-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2 class="m-0">Integration Intake Form</h2>
        </div>
        <div class="card-body">
            
            @* --- Section 1: Integration Allows --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">1. Integration Features</h3>
                <p class="text-muted">Select the capabilities this integration will support.</p>
                <div class="d-flex flex-wrap">
                    @foreach (var feature in _formModel.Features)
                    {
                        <div class="form-check form-check-inline mr-4">
                            <input class="form-check-input" type="checkbox" @bind="feature.IsEnabled" id="@feature.Name.Replace(" ", "-")">
                            <label class="form-check-label font-weight-bold" for="@feature.Name.Replace(" ", "-")">@feature.Name</label>
                        </div>
                    }
                </div>
            </section>

            @* --- Section 3: Required ID Fields --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">2. Required ID Fields Mapping</h3>
                <p class="text-muted">Define the specific mapping rules for each required ID field.</p>
                @foreach (var field in _formModel.RequiredIdFields)
                {
                    <MappingRuleEditor FieldName="@field.FieldName" @bind-Mapping="field.Mapping" />
                }
            </section>

            @* --- Section 4: Time Windows --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">3. Pickup / Delivery Target Time Windows Mapping</h3>
                
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="_formModel.MapInboundTimeWindows" id="map-time-windows">
                    <label class="form-check-label" for="map-time-windows">
                        Enable mapping as-is from inbound data (based on segment)
                    </label>
                </div>

                @* Conditional panel for time windows *@
                @if (_formModel.MapInboundTimeWindows)
                {
                    <div class="nested-option-panel border p-3 rounded mt-2 ml-4">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="_formModel.InboundDate_FromFile" id="inbound-date">
                            <label class="form-check-label" for="inbound-date">
                                ↳ Include Inbound Date (from file or custom logic?)
                            </label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="_formModel.InboundTime_FromFile" id="inbound-time">
                            <label class="form-check-label" for="inbound-time">
                                ↳ Include Inbound Time (from file or custom logic?)
                            </label>
                        </div>
                    </div>
                }
            </section>

            @* --- Section 5: Package Itemization --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">4. Package Itemization</h3>
                
                <div class="d-flex mb-3">
                    <div class="form-check mr-4">
                        <input class="form-check-input" type="radio" name="itemization" id="no-itemization" value="false" @onchange="() => OnItemizationChanged(false)" checked="@(!_formModel.EnableItemization)">
                        <label class="form-check-label" for="no-itemization">
                            No itemization
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="itemization" id="itemized" value="true" @onchange="() => OnItemizationChanged(true)" checked="@(_formModel.EnableItemization)">
                        <label class="form-check-label" for="itemized">
                            Itemized (with rules for type mapping)
                        </label>
                    </div>
                </div>

                @* Conditional panel 1 (No Itemization) *@
                @if (!_formModel.EnableItemization)
                {
                    <div class="nested-option-panel border p-3 rounded mt-2">
                        <p class="text-muted mb-2">How should the package type be determined?</p>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="no-item-type" id="type-from-file" value="@NoItemizationType.FromFileWithMapping" @onchange="OnNoItemSubOptionChanged">
                            <label class="form-check-label" for="type-from-file">
                                ↳ Type from file, based on mapping
                            </label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="no-item-type" id="singular-default" value="@NoItemizationType.SingularDefaultFromConfig" @onchange="OnNoItemSubOptionChanged">
                            <label class="form-check-label" for="singular-default">
                                ↳ Singular, default from config
                            </label>
                        </div>
                    </div>
                }

                @* Conditional panel 2 (Itemized) *@
                @if (_formModel.EnableItemization)
                {
                    <div class="form-group row mt-3 nested-option-panel p-2 rounded">
                        <label for="itemized-ref" class="col-sm-3 col-form-label font-weight-bold">↳ Reference Number mapping rule:</label>
                        <div class="col-sm-6">
                            <input type="text" class="form-control" id="itemized-ref" @bind="_formModel.ItemizedRefNoMapping" placeholder="e.g., item.ref_no">
                        </div>
                    </div>
                }
            </section>

            @* --- Section 6: Misc Notes --- *@
            <section class="form-section bg-light p-4 rounded mt-5">
                <h4 class="mb-3 text-secondary">General Notes & Instructions</h4>
                <ul class="list-group list-group-flush">
                    @foreach (var note in _formModel.MiscNotes)
                    {
                        <li class="list-group-item bg-light border-0 py-1">• @note</li>
                    }
                </ul>
            </section>
            
        </div>
        <div class="card-footer d-flex justify-content-end">
            <button class="btn btn-outline-secondary mr-2">Reset Form</button>
            <button class="btn btn-primary" @onclick="SubmitForm">Submit Integration Request</button>
        </div>
    </div>
</div>

@code {
    private IntegrationIntakeModel _formModel = new IntegrationIntakeModel();

    private void OnItemizationChanged(bool enabled)
    {
        _formModel.EnableItemization = enabled;
    }

    private void OnNoItemSubOptionChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<NoItemizationType>(e.Value?.ToString(), out var newType))
        {
            _formModel.NoItemizationSubOption = newType;
        }
    }

    private void SubmitForm()
    {
        // Add form submission logic here (e.g., API call)
        Console.WriteLine("Form submitted. Check console for model data.");
    }
}