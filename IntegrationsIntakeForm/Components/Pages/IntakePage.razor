@page "/intake"
@using IntegrationsIntakeForm
@using IntegrationsIntakeForm.Models
@rendermode InteractiveServer

<div class="container-fluid p-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2 class="m-0">Integration Intake Form</h2>
        </div>
        <div class="card-body">
            
            @* --- Section 1: Integration Features --- *@
            <section class="form-section mb-5">
                <h3 class="mb-3">1. Integration Features</h3>
                <p class="text-muted">Select the capabilities this integration will support.</p>
                <div class="d-flex flex-wrap">
                    @foreach (var feature in _formModel.Features)
                    {
                        <div class="form-check form-check-inline mr-4">
                            <input class="form-check-input" type="checkbox" @bind="feature.IsEnabled"
                                   id="@feature.Name.Replace(" ", "-")">
                                <label class="form-check-label font-weight-bold"
                                       for="@feature.Name.Replace(" ", "-")">@feature.Name</label>
                            </div>
                        }
                    </div>
                </section>

                @* --- Section 2: Required ID Fields --- *@
                <section class="form-section mb-5">
                    <h3 class="mb-3">2. Required ID Fields Mapping</h3>
                    <p class="text-muted">Define the specific mapping rules for each required ID field.</p>
                    @foreach (RequiredField field in _formModel.RequiredIdFields)
                    {
                        <MappingRuleEditor Field="@field" @bind-Mapping="field.Mapping" />
                    }
                </section>

                @* --- Section 3: Time Windows --- *@
                <section class="form-section mb-5">
                    <h3 class="mb-3">3. Pickup / Delivery Target Time Windows Mapping</h3>
                
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Field</th>
                                    <th class="text-center">Date Source</th>
                                    <th class="text-center">Time Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="font-weight-bold">Pickup From</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.PickupFromDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.PickupFromTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Pickup To</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm" @bind="_formModel.PickupToDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm" @bind="_formModel.PickupToTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Delivery From</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryFromDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryFromTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="font-weight-bold">Delivery To</td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryToDateSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <select class="form-control form-control-sm"
                                                @bind="_formModel.DeliveryToTimeSource">
                                            <option value="FromFile">From File</option>
                                            <option value="FromConfig">From Config</option>
                                            <option value="Custom">Custom Logic</option>
                                        </select>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                
            </div>
            <div class="card-footer d-flex justify-content-end">
                <button class="btn btn-outline-secondary mr-2" @onclick="ResetForm">Reset Form</button>
                <button class="btn btn-primary" @onclick="SubmitForm">Submit Integration Request</button>
            </div>
        </div>
    </div>

@code {
    private IntegrationIntakeModel _formModel = new IntegrationIntakeModel();
    
    private string GetLabelForType(NoItemizationType type)
    {
        return type switch
        {
            NoItemizationType.FromFileWithMapping => "From File (with mapping)",
            NoItemizationType.SingularDefaultFromConfig => "Singular Default (from config)",
            _ => type.ToString()
        };
    }

    private void ResetForm()
    {
        _formModel = new IntegrationIntakeModel();
    }

    private void SubmitForm()
    {
        Console.WriteLine("Form submitted. Check console for model data.");
    }
}